class DecimalEncoder(json.JSONEncoder):
    """Handle DynamoDB Decimal types in JSON serialization."""
    def default(self, obj):
        from decimal import Decimal
        if isinstance(obj, Decimal):
            return int(obj) if obj % 1 == 0 else float(obj)
        return super().default(obj)


def notify_doctor(patient_id, language, input_text, patient_record, comprehend_result=None):
    """Invoke aria-sns-notify to send triage summary to doctor."""
    try:
        payload = {
            "patient_id": patient_id,
            "summary": input_text,
            "key_symptoms": comprehend_result.get("key_symptoms", []) if comprehend_result else [],
            "urgency_keywords": comprehend_result.get("urgency_keywords", []) if comprehend_result else [],
        }

        resp = lambda_client.invoke(
            FunctionName=SNS_FN,
            InvocationType="RequestResponse",
            Payload=json.dumps(payload, cls=DecimalEncoder),
        )
        logger.info(f"SNS notification sent for {patient_id}")
        return json.loads(resp["Payload"].read())
    except Exception as e:
        logger.error(f"SNS notification failed for {patient_id}: {e}")
        return None


