# BEDROCK (Direct call using Converse API)
# ═══════════════════════════════════════════════════════════════════════

def call_bedrock(patient_id, patient_record, session_stage, input_text, language):
    """
    Call Amazon Bedrock via the Converse API (handles inference profiles automatically).
    Builds rich patient context from Lilian's DynamoDB schema.
    """
    # Extract fields from Lilian's schema
    first_name = patient_record.get("first_name", "")
    last_name = patient_record.get("last_name", "")
    id_number = patient_record.get("id_number", "")
    date_of_birth = patient_record.get("date_of_birth", "")
    gender = patient_record.get("gender", "")
    preferred_language = patient_record.get("preferred_language", language)
    registration_status = patient_record.get("registration_status", "unknown")
    current_stage = patient_record.get("current_stage", session_stage)
    assigned_doctor = patient_record.get("assigned_doctor", "not yet assigned")
    department = patient_record.get("department", "not yet assigned")
    next_station = patient_record.get("next_station", "not yet assigned")
    urgency_level = patient_record.get("urgency_level", "normal")
    fingerprint_verified = patient_record.get("fingerprint_verified", False)
    visit_history = patient_record.get("visit_history", [])
    registered_at = patient_record.get("registered_at", "")
    last_visit = patient_record.get("last_visit", "")
    transcript_english = patient_record.get("transcript_english", "")
    transcript_original = patient_record.get("transcript_original", "")

    verification_status = (
        "CONFIRMED via fingerprint biometrics (high confidence)"
        if fingerprint_verified
        else "Facial recognition only (standard confidence)"
    )

    # Get stage instruction
    stage_instruction = STAGE_INSTRUCTIONS.get(
        session_stage,
        "Respond helpfully based on what the patient said and their record details."
    )

    # Determine new stage
    stage_progression = {
        "post_registration": "navigation",
        "registered": "navigation",
        "navigation": "triage",
        "triage": "triage_complete",
        "triage_complete": "consultation_waiting",
        "consultation_waiting": "post_consultation",
        "post_consultation": next_station if next_station in ("pharmacy", "lab") else "discharge",
        "pharmacy": "discharge",
        "lab": "discharge",
    }

    user_message = f"""
{stage_instruction}

Patient Record:
- Patient ID: {patient_id}
- Name: {first_name} {last_name}
- ID Number: {id_number}
- Date of Birth: {date_of_birth}
- Gender: {gender}
- Identity Verification: {verification_status}
- Preferred Language: {preferred_language}
- Registration Status: {registration_status}
- Current Stage: {current_stage}
- Assigned Doctor: {assigned_doctor}
- Department: {department}
- Next Station: {next_station}
- Urgency Level: {urgency_level}
- Visit History: {json.dumps(visit_history, cls=DecimalEncoder) if visit_history else "First visit"}
- Registered At: {registered_at}
- Last Visit: {last_visit}
- Transcript (English): {transcript_english}
- Transcript (Original): {transcript_original}

Patient just said: "{input_text}"

Respond in English only. Translation happens separately.
Address the patient by their first name ({first_name}) if available.
Respond directly to the patient now.
""".strip()

    try:
        response = bedrock.converse(
            modelId=MODEL_ID,
            system=[{"text": SYSTEM_PROMPT}],
            messages=[{"role": "user", "content": [{"text": user_message}]}],
            inferenceConfig={
                "maxTokens": 300,
                "temperature": 0.3,
                "topP": 0.9,
            },
        )

        response_text = response["output"]["message"]["content"][0]["text"]
        logger.info(f"Bedrock response: {response_text}")

        # Parse triage decisions if present
        triage_decisions = extract_triage_decisions(response_text)
        new_stage = stage_progression.get(session_stage, session_stage)

        return {
            "response_text": clean_response_text(response_text),
            "new_stage": new_stage,
            "assigned_doctor": triage_decisions.get("assigned_doctor", ""),
            "department": triage_decisions.get("department", ""),
            "urgency_level": triage_decisions.get("urgency_level", ""),
        }

    except ClientError as e:
        error_code = e.response["Error"]["Code"]
        logger.error(f"Bedrock error ({error_code}): {e}")

        if error_code in ("ThrottlingException", "ServiceUnavailableException"):
            return {
                "response_text": "The system is busy. Please wait a moment or ask a staff member.",
                "new_stage": session_stage,
            }
        elif error_code == "AccessDeniedException":
            logger.error("Model access denied — check IAM policy and Bedrock model enablement")
            return {
                "response_text": "I couldn't process your request. A staff member will help you.",
                "new_stage": session_stage,
            }
        return {
            "response_text": "I couldn't process your request. A staff member will help you.",
            "new_stage": session_stage,
        }

    except Exception as e:
        logger.error(f"Unexpected Bedrock error: {e}")
        return {
            "response_text": "Something went wrong. Please ask a staff member for help.",
            "new_stage": session_stage,
        }


def extract_triage_decisions(response_text):
    """Extract JSON triage decisions from Bedrock's response."""
    try:
        start = response_text.find("{")
        end = response_text.rfind("}") + 1
        if start != -1 and end > start:
            json_str = response_text[start:end]
            decisions = json.loads(json_str)
            if "assigned_doctor" in decisions:
                return decisions
    except (json.JSONDecodeError, ValueError):
        pass
    return {}


def extract_next_station(response_text):
    """Extract next_station decision from Bedrock's end_consultation response."""
    try:
        start = response_text.find("{")
        end = response_text.rfind("}") + 1
        if start != -1 and end > start:
            json_str = response_text[start:end]
            decisions = json.loads(json_str)
            if "next_station" in decisions:
                return decisions
    except (json.JSONDecodeError, ValueError):
        pass
    return {}


def clean_response_text(response_text):
    """Remove JSON blocks from response text (keep only patient-facing message)."""
    try:
        start = response_text.find("{")
        end = response_text.rfind("}") + 1
        if start != -1 and end > start:
            json_str = response_text[start:end]
            parsed = json.loads(json_str)
            if "assigned_doctor" in parsed or "next_station" in parsed:
                cleaned = response_text[:start] + response_text[end:]
                return cleaned.strip()
    except (json.JSONDecodeError, ValueError):
        pass
    return response_text.strip()


