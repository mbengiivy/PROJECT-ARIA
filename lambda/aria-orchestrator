# DYNAMODB STREAM HANDLER
# ═══════════════════════════════════════════════════════════════════════

def handle_dynamodb_stream(records):
    """
    Handle DynamoDB Stream events.
    Triggered when Lilian's Lambda writes triage_ready = True.
    """
    for record in records:
        if record.get("eventName") not in ("INSERT", "MODIFY"):
            continue

        new_image = record.get("dynamodb", {}).get("NewImage", {})
        old_image = record.get("dynamodb", {}).get("OldImage", {})

        new_triage_ready = new_image.get("triage_ready", {}).get("BOOL", False)
        old_triage_ready = old_image.get("triage_ready", {}).get("BOOL", False)

        if not new_triage_ready or old_triage_ready:
            continue

        patient_id = new_image.get("patient_id", {}).get("S", "")
        if not patient_id:
            logger.warning("No patient_id in stream record, skipping")
            continue

        logger.info(f"DynamoDB Stream triggered for patient: {patient_id}")

        patient_record = get_patient_record(patient_id)
        if not patient_record:
            logger.error(f"Could not find patient record for {patient_id}")
            continue

        language = patient_record.get("preferred_language", "en")
        transcript_english = patient_record.get("transcript_english", "")
        transcript_original = patient_record.get("transcript_original", "")
        input_text = transcript_english if transcript_english else transcript_original

        if not input_text:
            logger.warning(f"No transcript found for {patient_id}")
            input_text = "Patient did not provide verbal input"

        logger.info(f"Processing triage for {patient_id} | Language: {language}")

        # Step 1: Extract medical entities
        comprehend_result = call_comprehend_medical(input_text)

        # Step 2: Build enriched input for Bedrock
        enriched_input = (
            f"Patient symptoms: {input_text}\n"
            f"Medical entities: {json.dumps(comprehend_result.get('medical_entities', []))}\n"
            f"Key symptoms: {json.dumps(comprehend_result.get('key_symptoms', []))}\n"
            f"Urgency indicators: {json.dumps(comprehend_result.get('urgency_keywords', []))}"
        )

        # Step 3: Call Bedrock for triage decision
        result = call_bedrock(patient_id, patient_record, "triage", enriched_input, language)

        # Step 4: Extract triage decisions
        assigned_doctor = result.get("assigned_doctor") or "Dr. On-Call"
        department = result.get("department") or "General Medicine"
        urgency_level = result.get("urgency_level") or "normal"

        # Step 5: Write triage results back to DynamoDB
        update_patient_after_triage(patient_id, assigned_doctor, department, urgency_level)

        # Step 6: Notify doctor via SNS
        notify_doctor(patient_id, language, input_text, patient_record, comprehend_result)

        logger.info(f"Triage complete for {patient_id}: {department} / {urgency_level} / {assigned_doctor}")


