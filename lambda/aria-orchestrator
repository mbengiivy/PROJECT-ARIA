# HEALTHSCRIBE (Synthesize audio → Start Medical Scribe Job)
# ═══════════════════════════════════════════════════════════════════════

def synthesize_conversation_audio(patient_id, transcript):
    """
    Synthesize the doctor-patient conversation into a 2-channel audio file using Polly.
    Doctor = Channel 0 (voice: Matthew), Patient = Channel 1 (voice: Joanna).
    Uploads to S3 and returns the S3 URI.
    """
    import struct
    import io

    lines = transcript.strip().split("\n")
    all_audio_bytes = []

    for line in lines:
        if not line.strip():
            continue

        if line.startswith("Doctor:"):
            voice_id = "Matthew"
            text = line.replace("Doctor:", "").strip()
        elif line.startswith("Patient:"):
            voice_id = "Joanna"
            text = line.replace("Patient:", "").strip()
        else:
            voice_id = "Joanna"
            text = line.strip()

        if not text:
            continue

        try:
            response = polly_client.synthesize_speech(
                Text=text,
                OutputFormat="pcm",
                VoiceId=voice_id,
                Engine="neural",
                SampleRate="16000",
            )
            audio_bytes = response["AudioStream"].read()
            all_audio_bytes.append(audio_bytes)
        except Exception as e:
            logger.warning(f"Polly synthesis failed for line: {e}")
            continue

    if not all_audio_bytes:
        logger.error("No audio generated from conversation")
        return None

    # Combine all PCM audio into a single WAV file
    combined_pcm = b"".join(all_audio_bytes)
    wav_buffer = io.BytesIO()

    # Write WAV header (16-bit PCM, mono, 16kHz)
    num_channels = 1
    sample_rate = 16000
    bits_per_sample = 16
    byte_rate = sample_rate * num_channels * bits_per_sample // 8
    block_align = num_channels * bits_per_sample // 8
    data_size = len(combined_pcm)

    wav_buffer.write(b"RIFF")
    wav_buffer.write(struct.pack("<I", 36 + data_size))
    wav_buffer.write(b"WAVE")
    wav_buffer.write(b"fmt ")
    wav_buffer.write(struct.pack("<I", 16))  # chunk size
    wav_buffer.write(struct.pack("<H", 1))   # PCM format
    wav_buffer.write(struct.pack("<H", num_channels))
    wav_buffer.write(struct.pack("<I", sample_rate))
    wav_buffer.write(struct.pack("<I", byte_rate))
    wav_buffer.write(struct.pack("<H", block_align))
    wav_buffer.write(struct.pack("<H", bits_per_sample))
    wav_buffer.write(b"data")
    wav_buffer.write(struct.pack("<I", data_size))
    wav_buffer.write(combined_pcm)

    # Upload to S3
    from datetime import datetime
    timestamp = datetime.now().strftime("%Y%m%d%H%M%S")
    audio_key = f"healthscribe/input/{patient_id}/{timestamp}.wav"

    try:
        s3_client.put_object(
            Bucket=HEALTHSCRIBE_BUCKET,
            Key=audio_key,
            Body=wav_buffer.getvalue(),
            ContentType="audio/wav",
        )
        s3_uri = f"s3://{HEALTHSCRIBE_BUCKET}/{audio_key}"
        logger.info(f"Conversation audio uploaded: {s3_uri}")
        return s3_uri
    except Exception as e:
        logger.error(f"Failed to upload conversation audio: {e}")
        return None


def start_healthscribe_job(patient_id, audio_s3_uri):
    """
    Start an AWS HealthScribe Medical Scribe job.
    Returns the job name for polling.
    """
    from datetime import datetime
    timestamp = datetime.now().strftime("%Y%m%d%H%M%S")
    # Job name must be <= 200 chars, only [a-zA-Z0-9._-]
    safe_patient = patient_id.replace(" ", "-")[-20:]
    job_name = f"aria-scribe-{safe_patient}-{timestamp}"

    try:
        logger.info(f"Calling start_medical_scribe_job: {job_name} | Media: {audio_s3_uri} | Bucket: {HEALTHSCRIBE_BUCKET} | Role: {HEALTHSCRIBE_ROLE_ARN}")

        response = transcribe_client.start_medical_scribe_job(
            MedicalScribeJobName=job_name,
            Media={"MediaFileUri": audio_s3_uri},
            OutputBucketName=HEALTHSCRIBE_BUCKET,
            DataAccessRoleArn=HEALTHSCRIBE_ROLE_ARN,
            
            ChannelDefinitions=[
                {
                    "ChannelId": 0,
                    "ParticipantRole": "CLINICIAN"
                },
                {
                    "ChannelId": 1,
                    "ParticipantRole": "PATIENT"
                }
            ]
        )
        logger.info(f"HealthScribe job started successfully: {job_name}")
        return job_name
    except Exception as e:
        logger.error(f"Failed to start HealthScribe job: {type(e).__name__}: {e}")
        return None


def get_healthscribe_results(job_name):
    """
    Poll HealthScribe job and return clinical notes if complete.
    Returns: (status, clinical_notes_or_none)
    """
    try:
        response = transcribe_client.get_medical_scribe_job(
            MedicalScribeJobName=job_name
        )
        job = response.get("MedicalScribeJob", {})
        status = job.get("MedicalScribeJobStatus", "UNKNOWN")

        if status == "COMPLETED":
            # Get the clinical document output
            output = job.get("MedicalScribeOutput", {})
            clinical_doc_uri = output.get("ClinicalDocumentUri", "")
            transcript_uri = output.get("TranscriptFileUri", "")

            clinical_notes = ""

            # Fetch clinical document from S3
            if clinical_doc_uri:
                try:
                    # Parse S3 URI
                    parts = clinical_doc_uri.replace("s3://", "").split("/", 1)
                    bucket = parts[0]
                    key = parts[1]

                    obj = s3_client.get_object(Bucket=bucket, Key=key)
                    doc_content = json.loads(obj["Body"].read())

                    # Extract clinical notes sections
                    sections = doc_content.get("ClinicalDocumentation", {}).get("Sections", [])
                    for section in sections:
                        section_name = section.get("SectionName", "")
                        summary = section.get("Summary", [])
                        summary_text = " ".join([s.get("SummarizedSegment", "") for s in summary])
                        if summary_text:
                            clinical_notes += f"\n{section_name}:\n{summary_text}\n"

                except Exception as e:
                    logger.error(f"Failed to fetch clinical document: {e}")
                    clinical_notes = "Clinical document available but could not be retrieved."

            return status, clinical_notes.strip() if clinical_notes else "No clinical notes generated."

        elif status == "FAILED":
            failure_reason = job.get("FailureReason", "Unknown failure")
            logger.error(f"HealthScribe job failed: {failure_reason}")
            return status, None

        else:
            return status, None

    except Exception as e:
        logger.error(f"Failed to get HealthScribe results: {e}")
        return "ERROR", None


