# MAIN HANDLER
# ═══════════════════════════════════════════════════════════════════════

def lambda_handler(event, context):
    """
    Entry point. Receives input from:
    1. DynamoDB Streams (when triage_ready = True)
    2. Web app (API Gateway)
    3. Lilian's Registration Lambda (direct invoke)
    """
    logger.info(f"Received event: {json.dumps(event)}")

    # ── DYNAMODB STREAM EVENT ───────────────────────────────────────────
    if "Records" in event and event["Records"][0].get("eventSource") == "aws:dynamodb":
        logger.info("Processing DynamoDB Stream event")
        handle_dynamodb_stream(event["Records"])
        return {"statusCode": 200, "body": json.dumps({"status": "stream_processed"})}

    # ── API GATEWAY / DIRECT INVOKE ─────────────────────────────────────
    if "body" in event:
        body = json.loads(event["body"]) if isinstance(event["body"], str) else event["body"]
    else:
        body = event

    patient_id = body.get("patient_id", "")
    input_text = body.get("input_text", "")
    language = body.get("language", "en")
    session_stage = body.get("session_stage", "")

    logger.info(f"Stage: {session_stage} | Patient: {patient_id} | Lang: {language}")

    # Hardcoded responses
    if session_stage in HARDCODED_RESPONSES:
        response_text = HARDCODED_RESPONSES[session_stage]
        return build_response(response_text, language, session_stage)

    # Look up patient record
    patient_record = {}
    if patient_id:
        record = get_patient_record(patient_id)
        if record:
            patient_record = record
            if not language or language == "en":
                record_lang = record.get("preferred_language", "en")
                if record_lang:
                    language = record_lang
            if not session_stage:
                session_stage = record.get("current_stage", "")

    # ── TRIAGE (direct invoke path — not from stream) ───────────────────
    if session_stage == "triage":
        comprehend_result = call_comprehend_medical(input_text)
        enriched_input = (
            f"Patient symptoms: {input_text}\n"
            f"Medical entities: {json.dumps(comprehend_result.get('medical_entities', []))}\n"
            f"Key symptoms: {json.dumps(comprehend_result.get('key_symptoms', []))}\n"
            f"Urgency indicators: {json.dumps(comprehend_result.get('urgency_keywords', []))}"
        )
        result = call_bedrock(patient_id, patient_record, session_stage, enriched_input, language)

        assigned_doctor = result.get("assigned_doctor") or "Dr. On-Call"
        department = result.get("department") or "General Medicine"
        urgency_level = result.get("urgency_level") or "normal"

        if patient_id:
            update_patient_after_triage(patient_id, assigned_doctor, department, urgency_level)
            notify_doctor(patient_id, language, input_text, patient_record, comprehend_result)

        return build_response(result.get("response_text", ""), language, "triage_complete")

    # ── TRIAGE COMPLETE → direct patient to doctor ──────────────────────
    if session_stage == "triage_complete":
        result = call_bedrock(patient_id, patient_record, session_stage, input_text, language)
        new_stage = result.get("new_stage", "consultation_waiting")
        if patient_id:
            update_patient_stage(patient_id, new_stage)
        return build_response(result.get("response_text", ""), language, new_stage)

    # ── END CONSULTATION → analyze conversation, decide next station ────
    if session_stage == "end_consultation":
        # input_text contains the full conversation transcript from the frontend
        logger.info(f"End consultation for {patient_id}, analyzing conversation...")

        # Step 1: Extract medical entities from the conversation
        comprehend_result = call_comprehend_medical(input_text)

        # Step 2: Build enriched input for Bedrock
        enriched_input = (
            f"Full doctor-patient conversation transcript:\n{input_text}\n\n"
            f"Medical entities found in conversation: {json.dumps(comprehend_result.get('medical_entities', []))}\n"
            f"Key medical conditions/symptoms discussed: {json.dumps(comprehend_result.get('key_symptoms', []))}\n"
            f"Urgency indicators: {json.dumps(comprehend_result.get('urgency_keywords', []))}"
        )

        # Step 3: Call Bedrock to decide next station
        result = call_bedrock(patient_id, patient_record, "end_consultation", enriched_input, language)

        # Step 4: Extract next_station from Bedrock's response
        raw_response = result.get("response_text", "")
        # Re-parse the full Bedrock output (before clean_response_text strips the JSON)
        # We need to check the original response for the JSON block
        station_decision = extract_next_station(raw_response) if "{" in raw_response else {}
        # If clean_response_text already stripped it, try from the full bedrock call
        if not station_decision:
            # Fallback: default to pharmacy if medications mentioned, lab if tests mentioned
            symptoms = comprehend_result.get("key_symptoms", [])
            entities_text = " ".join([e.get("text", "") for e in comprehend_result.get("medical_entities", [])])
            if any(word in entities_text.lower() for word in ["prescription", "medication", "drug", "tablet", "dose"]):
                station_decision = {"next_station": "pharmacy", "reason": "Medication prescribed"}
            elif any(word in entities_text.lower() for word in ["test", "blood", "lab", "scan", "xray", "x-ray", "sample"]):
                station_decision = {"next_station": "lab", "reason": "Tests ordered"}
            else:
                station_decision = {"next_station": "discharge", "reason": "No further action needed"}

        next_station = station_decision.get("next_station", "discharge")
        if next_station not in ("pharmacy", "lab", "discharge"):
            next_station = "discharge"

        # Step 5: Update DynamoDB
        if patient_id:
            update_patient_next_station(patient_id, next_station, input_text[:500])

        # Step 6: Kick off HealthScribe ASYNCHRONOUSLY (self-invoke with Event type)
        if HEALTHSCRIBE_ROLE_ARN and input_text and patient_id:
            try:
                lambda_client.invoke(
                    FunctionName=os.environ.get("AWS_LAMBDA_FUNCTION_NAME", "aria-orchestrator"),
                    InvocationType="Event",  # Fire-and-forget, returns immediately
                    Payload=json.dumps({
                        "patient_id": patient_id,
                        "session_stage": "run_healthscribe",
                        "input_text": input_text,
                        "language": language,
                    }),
                )
                logger.info(f"Async HealthScribe invocation triggered for {patient_id}")
            except Exception as e:
                logger.error(f"Failed to trigger async HealthScribe: {e}")

        # Step 7: Get directions for the next station (returns fast)
        direction_result = call_bedrock(patient_id, patient_record, next_station, "Where do I go now?", language)
        response_text = direction_result.get("response_text", result.get("response_text", ""))

        return build_response(response_text, language, next_station)

    # ── RUN HEALTHSCRIBE (async self-invoked, no response needed) ──────
    if session_stage == "run_healthscribe":
        logger.info(f"Async HealthScribe handler for {patient_id}")

        if not patient_id or not input_text:
            logger.error("run_healthscribe: missing patient_id or input_text")
            return {"statusCode": 200, "body": json.dumps({"status": "skipped"})}

        # Step 1: Synthesize conversation to stereo audio
        logger.info(f"Synthesizing conversation audio for {patient_id}...")
        audio_s3_uri = synthesize_conversation_audio(patient_id, input_text)
        if not audio_s3_uri:
            logger.error(f"Audio synthesis failed for {patient_id}")
            return {"statusCode": 200, "body": json.dumps({"status": "audio_failed"})}

        # Step 2: Start HealthScribe job
        logger.info(f"Starting HealthScribe job for {patient_id}...")
        healthscribe_job_name = start_healthscribe_job(patient_id, audio_s3_uri)
        if not healthscribe_job_name:
            logger.error(f"HealthScribe job start failed for {patient_id}")
            return {"statusCode": 200, "body": json.dumps({"status": "healthscribe_start_failed"})}

        # Step 3: Store job name in DynamoDB
        table = dynamodb.Table(TABLE_NAME)
        try:
            table.update_item(
                Key={"patient_id": patient_id},
                UpdateExpression="SET healthscribe_job = :hj",
                ExpressionAttributeValues={":hj": healthscribe_job_name},
            )
            logger.info(f"HealthScribe job name stored: {healthscribe_job_name}")
        except Exception as e:
            logger.error(f"Failed to store HealthScribe job name: {e}")

        return {"statusCode": 200, "body": json.dumps({"status": "healthscribe_started", "job_name": healthscribe_job_name})}

    # ── GET CLINICAL NOTES → poll HealthScribe and send via SNS ────────
    if session_stage == "get_clinical_notes":
        if not patient_id:
            return build_response("Patient ID required.", language, "get_clinical_notes")

        # Get job name from DynamoDB
        healthscribe_job = patient_record.get("healthscribe_job", "")
        if not healthscribe_job:
            return build_response("No HealthScribe job found for this patient.", language, "get_clinical_notes")

        status, clinical_notes = get_healthscribe_results(healthscribe_job)

        if status == "COMPLETED" and clinical_notes:
            # Format and send clinical notes to doctor via SNS
            formatted_notes = (
                f"📋 CLINICAL NOTES — HealthScribe\n"
                f"{'='*40}\n"
                f"Patient: {patient_id}\n"
                f"Doctor: {patient_record.get('assigned_doctor', 'Unknown')}\n"
                f"Department: {patient_record.get('department', 'Unknown')}\n"
                f"{'='*40}\n\n"
                f"{clinical_notes}\n\n"
                f"{'='*40}\n"
                f"Generated by AWS HealthScribe"
            )
            send_clinical_notes_sns(patient_id, formatted_notes)
            return build_response("Clinical notes generated and sent to doctor.", language, "discharge")
        elif status == "FAILED":
            return build_response("Clinical notes generation failed.", language, "discharge")
        else:
            return build_response("Clinical notes are still being generated. Please check again shortly.", language, "get_clinical_notes")

    # ── DISCHARGE → append visit history ────────────────────────────────
    if session_stage == "discharge":
        result = call_bedrock(patient_id, patient_record, session_stage, input_text, language)
        if patient_id:
            visit_summary = {
                "date": body.get("timestamp", ""),
                "reason": patient_record.get("triage_summary", ""),
                "doctor": patient_record.get("assigned_doctor", ""),
                "outcome": "completed",
            }
            append_visit_history(patient_id, visit_summary)
            update_patient_stage(patient_id, "discharge")
        return build_response(result.get("response_text", ""), language, "discharge")

    # ── DEFAULT: Call Bedrock for any other stage ────────────────────────
    result = call_bedrock(patient_id, patient_record, session_stage, input_text, language)
    new_stage = result.get("new_stage", session_stage)
    if patient_id and new_stage != session_stage:
        update_patient_stage(patient_id, new_stage)
    return build_response(result.get("response_text", ""), language, new_stage)
