def get_patient_record(patient_id):
    """Fetch patient record from DynamoDB."""
    table = dynamodb.Table(TABLE_NAME)
    try:
        resp = table.get_item(Key={"patient_id": patient_id})
        return resp.get("Item")
    except ClientError as e:
        logger.error(f"DynamoDB error for {patient_id}: {e}")
        return None


def update_patient_stage(patient_id, new_stage):
    """Update the patient's current_stage in DynamoDB."""
    table = dynamodb.Table(TABLE_NAME)
    try:
        table.update_item(
            Key={"patient_id": patient_id},
            UpdateExpression="SET current_stage = :s",
            ExpressionAttributeValues={":s": new_stage},
        )
    except ClientError as e:
        logger.error(f"Failed to update stage for {patient_id}: {e}")


def update_patient_after_triage(patient_id, assigned_doctor, department, urgency_level):
    """Update DynamoDB with triage decisions."""
    table = dynamodb.Table(TABLE_NAME)
    try:
        table.update_item(
            Key={"patient_id": patient_id},
            UpdateExpression=(
                "SET assigned_doctor = :doc, "
                "department = :dept, "
                "urgency_level = :urg, "
                "current_stage = :stage, "
                "next_station = :ns, "
                "triage_complete = :tc"
            ),
            ExpressionAttributeValues={
                ":doc": assigned_doctor,
                ":dept": department,
                ":urg": urgency_level,
                ":stage": "triage_complete",
                ":ns": "consultation",
                ":tc": True,
            },
        )
        logger.info(f"Updated triage decisions for {patient_id}")
    except ClientError as e:
        logger.error(f"Failed to update triage decisions for {patient_id}: {e}")


def append_visit_history(patient_id, visit_summary):
    """Append a visit summary to the patient's visit_history array."""
    table = dynamodb.Table(TABLE_NAME)
    try:
        table.update_item(
            Key={"patient_id": patient_id},
            UpdateExpression="SET visit_history = list_append(if_not_exists(visit_history, :empty), :visit)",
            ExpressionAttributeValues={
                ":visit": [visit_summary],
                ":empty": [],
            },
        )
    except ClientError as e:
        logger.error(f"Failed to append visit history for {patient_id}: {e}")


def update_patient_next_station(patient_id, next_station, consultation_summary=""):
    """Update DynamoDB with post-consultation next_station decision."""
    table = dynamodb.Table(TABLE_NAME)
    try:
        table.update_item(
            Key={"patient_id": patient_id},
            UpdateExpression="SET next_station = :ns, current_stage = :stage, consultation_summary = :cs",
            ExpressionAttributeValues={
                ":ns": next_station,
                ":stage": "post_consultation",
                ":cs": consultation_summary,
            },
        )
        logger.info(f"Updated next_station for {patient_id}: {next_station}")
    except ClientError as e:
        logger.error(f"Failed to update next_station for {patient_id}: {e}")


