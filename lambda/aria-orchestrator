# COMPREHEND MEDICAL (Direct call)
# ═══════════════════════════════════════════════════════════════════════

def call_comprehend_medical(input_text):
    """Extract medical entities from symptom text using Comprehend Medical."""
    try:
        response = comprehend_medical.detect_entities_v2(Text=input_text)
        entities = response.get("Entities", [])

        medical_entities = []
        key_symptoms = []
        urgency_keywords = []

        urgency_terms = ["chest pain", "breathing", "unconscious", "bleeding",
                         "severe", "emergency", "critical", "acute", "sudden"]

        for entity in entities:
            entity_data = {
                "text": entity.get("Text", ""),
                "category": entity.get("Category", ""),
                "type": entity.get("Type", ""),
                "score": round(entity.get("Score", 0), 3),
            }
            medical_entities.append(entity_data)

            if entity.get("Category") in ("MEDICAL_CONDITION", "SYMPTOM"):
                key_symptoms.append(entity.get("Text", ""))

            if any(term in entity.get("Text", "").lower() for term in urgency_terms):
                urgency_keywords.append(entity.get("Text", ""))

        logger.info(f"Comprehend Medical found {len(medical_entities)} entities")
        return {
            "medical_entities": medical_entities,
            "key_symptoms": key_symptoms,
            "urgency_keywords": urgency_keywords,
        }

    except ClientError as e:
        logger.error(f"Comprehend Medical error: {e}")
        return {"medical_entities": [], "key_symptoms": [], "urgency_keywords": []}


