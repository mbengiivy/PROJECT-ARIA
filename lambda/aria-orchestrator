def build_response(response_text, language, new_stage):
    """Build the standard response for the web app."""
    polly_voice = POLLY_VOICES.get(language, "Joanna")
    return {
        "statusCode": 200,
        "headers": {
            "Content-Type": "application/json",
            "Access-Control-Allow-Origin": "*",
        },
        "body": json.dumps({
            "response_text": response_text,
            "target_language": language,
            "polly_voice": polly_voice,
            "speak": True,
            "new_stage": new_stage,
        }),
    }


